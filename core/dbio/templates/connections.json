    "duckdb": {
      "name": "DuckDB",
      "description": "DuckDB embedded database connection",
      "category": "database",
      "properties": {
        "instance": {
          "type": "string",
          "description": "Local file path of the database file",
          "required": true,
          "examples": ["/path/to/database.db", "./data/mydatabase.duckdb"]
        },
        "schema": {
          "type": "string",
          "description": "Default schema name",
